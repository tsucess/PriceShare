# =============================================================================
# PriceShare Frontend — Environment Variables Template
# =============================================================================
# 1. Copy this file:  cp .env.example .env
# 2. Fill in the values for your environment.
# 3. NEVER commit .env — it is listed in .gitignore.
# =============================================================================

# ── API ───────────────────────────────────────────────────────────────────────
# Development  : http://localhost:8000/api
# Production   : https://api.yourdomain.com/api
REACT_APP_API_URL=

# ── Storage Keys ─────────────────────────────────────────────────────────────
REACT_APP_TOKEN_KEY=ps-token
REACT_APP_ONBOARD_KEY=pw-onboarded

# ── App Identity ──────────────────────────────────────────────────────────────
REACT_APP_NAME=PriceShare
REACT_APP_VERSION=1.0.0

# ── Request Timeout (milliseconds) ───────────────────────────────────────────
REACT_APP_API_TIMEOUT=10000
